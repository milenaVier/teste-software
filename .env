PORT=3000               # porta do servidor web normalmente utilizada para apps node
DB_HOST=localhost       # nome do servidor do banco de dados
DB_PORT=3306            # porta do servidor do banco de dados
DB_USER=root            # nome do usuário para o banco de dados
DB_PASSWORD=root        # senha do usuário para o banco de dados
DB_NAME=teste_software  # nome do banco de dados criado há pouco
SESSION_SECRET=segredo  # chave secreta usada para assinar sessões de usuário
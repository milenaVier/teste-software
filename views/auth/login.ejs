<!DOCTYPE html>
<html lang="pt-br">
<head>
    <%- include("../partials/head") %>
</head>
<body>
    <%- include("../partials/navbar") %>
    <%- include("../partials/messages") %>

    <main class="container d-flex align-items-center justify-content-center my-auto py-5">
        <div class="row w-100 justify-content-center">
            <div class="col-md-7 col-lg-5 col-xl-4">
                <div class="card catolica-card border-0 shadow-lg">
                    <!-- Top accent bar -->
                    <div class="catolica-card-header-bar"></div>
                    
                    <div class="p-4 p-sm-5">
                        <!-- Logo & Brand Header -->
                        <div class="text-center mb-4">
                            <img src="/images/logo-catolica.png" alt="Católica SC Logo" class="img-fluid mb-3" style="max-height: 55px;">
                            <h3 class="fw-bold text-dark tracking-tight">Portal de Acesso</h3>
                            <p class="text-muted small">Entre com suas credenciais acadêmicas.</p>
                        </div>

                        <!-- Login Form -->
                        <form action="/login" method="POST" class="needs-validation" novalidate>
                            <!-- Email or Username -->
                            <div class="form-floating mb-3">
                                <input type="text" class="form-control" id="loginInput" name="login" placeholder="Email ou Usuário" required autocomplete="username">
                                <label for="loginInput"><i class="bi bi-person me-2"></i>E-mail ou Usuário</label>
                                <div class="invalid-feedback">Por favor, insira seu e-mail ou usuário.</div>
                            </div>

                            <!-- Password with toggle -->
                            <div class="mb-4">
                                <div class="input-group password-group">
                                    <div class="form-floating flex-grow-1">
                                        <input type="password" class="form-control" id="passwordInput" name="password" placeholder="Senha" required autocomplete="current-password">
                                        <label for="passwordInput"><i class="bi bi-key me-2"></i>Senha</label>
                                    </div>
                                    <button class="btn password-toggle-btn px-3" type="button" id="togglePassword">
                                        <i class="bi bi-eye" id="toggleIcon"></i>
                                    </button>
                                </div>
                                <div class="invalid-feedback d-block text-danger small mt-1" id="passwordFeedback" style="display: none;"></div>
                            </div>

                            <!-- Remember me -->
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check">
                                    <input class="form-check-input border-secondary" type="checkbox" id="rememberMe">
                                    <label class="form-check-label text-secondary small" for="rememberMe">Lembrar-me</label>
                                </div>
                                <a href="#" class="text-decoration-none small hover-link fw-semibold" style="color: var(--primary-color);">Esqueceu a senha?</a>
                            </div>

                            <!-- Submit Button -->
                            <button type="submit" class="btn btn-catolica w-100 py-3 rounded-pill fw-bold fs-6 shadow-sm mb-3">
                                <i class="bi bi-box-arrow-in-right me-2"></i> Entrar
                            </button>
                        </form>

                        <!-- Bottom CTA -->
                        <div class="text-center mt-3">
                            <span class="text-secondary small">Não tem uma conta? </span>
                            <a href="/register" class="text-decoration-none small hover-link fw-bold" style="color: var(--primary-color);">Cadastre-se</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include("../partials/footer") %>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Password toggle script -->
    <script>
        const togglePassword = document.querySelector('#togglePassword');
        const passwordInput = document.querySelector('#passwordInput');
        const toggleIcon = document.querySelector('#toggleIcon');

        togglePassword.addEventListener('click', function () {
            const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordInput.setAttribute('type', type);
            toggleIcon.classList.toggle('bi-eye');
            toggleIcon.classList.toggle('bi-eye-slash');
        });

        // Bootstrap basic validation triggers
        (() => {
            'use strict'
            const forms = document.querySelectorAll('.needs-validation')
            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
        })()
    </script>
</body>
</html>
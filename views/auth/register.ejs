<!DOCTYPE html>
<html lang="pt-br">
<head>
    <%- include("../partials/head") %>
</head>
<body>
    <%- include("../partials/navbar") %>
    <%- include("../partials/messages") %>

    <main class="container d-flex align-items-center justify-content-center my-auto py-5">
        <div class="row w-100 justify-content-center">
            <div class="col-md-9 col-lg-7 col-xl-6">
                <div class="card catolica-card border-0 shadow-lg">
                    <!-- Top accent bar -->
                    <div class="catolica-card-header-bar"></div>

                    <div class="p-4 p-sm-5">
                        <!-- Logo & Brand Header -->
                        <div class="text-center mb-4">
                            <img src="/images/logo-catolica.png" alt="Católica SC Logo" class="img-fluid mb-3" style="max-height: 55px;">
                            <h3 class="fw-bold text-dark tracking-tight">Criar Nova Conta</h3>
                            <p class="text-muted small">Preencha os dados abaixo para cadastrar-se no portal.</p>
                        </div>

                        <!-- Register Form -->
                        <form action="/register" method="POST" id="registerForm" class="needs-validation" novalidate>
                            <div class="row">
                                <!-- Full Name -->
                                <div class="col-md-12 mb-3">
                                    <div class="form-floating">
                                        <input type="text" class="form-control" id="fullNameInput" name="fullName" placeholder="Nome Completo" required autocomplete="name">
                                        <label for="fullNameInput"><i class="bi bi-card-text me-2"></i>Nome Completo</label>
                                        <div class="invalid-feedback">Por favor, insira seu nome completo.</div>
                                    </div>
                                </div>
                                
                                <!-- Username -->
                                <div class="col-md-6 mb-3">
                                    <div class="form-floating">
                                        <input type="text" class="form-control" id="usernameInput" name="username" placeholder="Usuário" required autocomplete="username">
                                        <label for="usernameInput"><i class="bi bi-person me-2"></i>Nome de Usuário</label>
                                        <div class="invalid-feedback">Insira um nome de usuário único.</div>
                                    </div>
                                </div>

                                <!-- Email -->
                                <div class="col-md-6 mb-3">
                                    <div class="form-floating">
                                        <input type="email" class="form-control" id="emailInput" name="email" placeholder="E-mail" required autocomplete="email">
                                        <label for="emailInput"><i class="bi bi-envelope me-2"></i>E-mail</label>
                                        <div class="invalid-feedback">Insira um e-mail válido.</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Password -->
                            <div class="mb-3">
                                <div class="input-group password-group">
                                    <div class="form-floating flex-grow-1">
                                        <input type="password" class="form-control" id="passwordInput" name="password" placeholder="Senha" required autocomplete="new-password">
                                        <label for="passwordInput"><i class="bi bi-key me-2"></i>Senha</label>
                                    </div>
                                    <button class="btn password-toggle-btn px-3" type="button" id="togglePassword">
                                        <i class="bi bi-eye" id="toggleIcon"></i>
                                    </button>
                                </div>
                                <div class="invalid-feedback d-block text-danger small mt-1" id="passwordStrengthFeedback"></div>
                            </div>

                            <!-- Confirm Password -->
                            <div class="mb-4">
                                <div class="input-group password-group">
                                    <div class="form-floating flex-grow-1">
                                        <input type="password" class="form-control" id="confirmPasswordInput" name="confirmPassword" placeholder="Confirmar Senha" required autocomplete="new-password">
                                        <label for="confirmPasswordInput"><i class="bi bi-check-all me-2"></i>Confirmar Senha</label>
                                    </div>
                                    <button class="btn password-toggle-btn px-3" type="button" id="toggleConfirmPassword">
                                        <i class="bi bi-eye" id="toggleConfirmIcon"></i>
                                    </button>
                                </div>
                                <div class="invalid-feedback d-block text-danger small mt-1" id="passwordMatchFeedback"></div>
                            </div>

                            <!-- Terms Checkbox -->
                            <div class="form-check mb-4">
                                <input class="form-check-input border-secondary" type="checkbox" id="termsCheck" required>
                                <label class="form-check-label text-secondary small" for="termsCheck">
                                    Eu concordo com as políticas de devolução e os <a href="#" class="text-decoration-none hover-link fw-semibold" style="color: var(--primary-color);">Termos de Uso</a> do campus.
                                </label>
                                <div class="invalid-feedback">Você precisa aceitar os termos para se cadastrar.</div>
                            </div>

                            <!-- Submit Button -->
                            <button type="submit" class="btn btn-catolica w-100 py-3 rounded-pill fw-bold fs-6 shadow-sm mb-3">
                                <i class="bi bi-person-check me-2"></i> Registrar Conta
                            </button>
                        </form>

                        <!-- Bottom CTA -->
                        <div class="text-center mt-2">
                            <span class="text-secondary small">Já possui uma conta? </span>
                            <a href="/login" class="text-decoration-none small hover-link fw-bold" style="color: var(--primary-color);">Entrar</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include("../partials/footer") %>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Scripts for Password Toggles and Validation -->
    <script>
        const setupPasswordToggle = (buttonId, inputId, iconId) => {
            const button = document.querySelector(buttonId);
            const input = document.querySelector(inputId);
            const icon = document.querySelector(iconId);

            button.addEventListener('click', function () {
                const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
                input.setAttribute('type', type);
                icon.classList.toggle('bi-eye');
                icon.classList.toggle('bi-eye-slash');
            });
        };

        setupPasswordToggle('#togglePassword', '#passwordInput', '#toggleIcon');
        setupPasswordToggle('#toggleConfirmPassword', '#confirmPasswordInput', '#toggleConfirmIcon');

        const form = document.querySelector('#registerForm');
        const password = document.querySelector('#passwordInput');
        const confirmPassword = document.querySelector('#confirmPasswordInput');
        const passwordMatchFeedback = document.querySelector('#passwordMatchFeedback');

        confirmPassword.addEventListener('input', function() {
            if (password.value !== confirmPassword.value) {
                passwordMatchFeedback.textContent = 'As senhas não coincidem!';
                confirmPassword.setCustomValidity('Passwords do not match');
            } else {
                passwordMatchFeedback.textContent = '';
                confirmPassword.setCustomValidity('');
            }
        });

        password.addEventListener('input', function() {
            if (confirmPassword.value && password.value !== confirmPassword.value) {
                passwordMatchFeedback.textContent = 'As senhas não coincidem!';
                confirmPassword.setCustomValidity('Passwords do not match');
            } else {
                passwordMatchFeedback.textContent = '';
                confirmPassword.setCustomValidity('');
            }
        });

        (() => {
            'use strict'
            const forms = document.querySelectorAll('.needs-validation')
            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {
                    if (password.value !== confirmPassword.value) {
                        passwordMatchFeedback.textContent = 'As senhas não coincidem!';
                        confirmPassword.setCustomValidity('Passwords do not match');
                    }

                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
        })()
    </script>
</body>
</html>

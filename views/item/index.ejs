<!DOCTYPE html>
<html lang="pt-br">
<head>
    <%- include("../partials/head") %>
</head>
<body>
    <%- include("../partials/navbar") %>
    <%- include("../partials/messages") %>

    <main class="container my-5">
        <!-- Feed Header -->
        <div class="row align-items-center mb-5">
            <div class="col-md-6 mb-3 mb-md-0">
                <span class="badge px-3 py-2 rounded-pill fw-semibold mb-2" style="background-color: var(--primary-light); color: var(--primary-color);">
                    <i class="bi bi-tag-fill me-1"></i> Católica SC
                </span>
                <h1 class="fw-bold text-dark mb-1">Mural de Achados e Perdidos</h1>
                <p class="text-secondary mb-0">Ajude a encontrar e devolver pertences no campus da universidade.</p>
            </div>
            <div class="col-md-6 text-md-end">
                <% if (user) { %>
                    <a href="/items/new" class="btn btn-catolica px-4 py-3 rounded-pill shadow-sm">
                        <i class="bi bi-plus-circle-fill me-2"></i> Registrar Novo Item
                    </a>
                <% } else { %>
                    <a href="/login" class="btn btn-outline-catolica px-4 py-3 rounded-pill shadow-sm">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Entre para Registrar Item
                    </a>
                <% } %>
            </div>
        </div>

        <!-- Search & Filter Form -->
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-5" style="background-color: #ffffff;">
            <form action="/items" method="GET" class="row g-3 align-items-end">
                <!-- Search Input -->
                <div class="col-lg-5 col-md-6">
                    <label for="searchInput" class="form-label text-dark fw-semibold small"><i class="bi bi-search me-1"></i> Buscar por nome ou palavra-chave</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-light text-secondary"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control bg-light border-light" id="searchInput" name="search" placeholder="Ex: Garrafa de água, caderno, fone de ouvido..." value="<%= typeof search !== 'undefined' ? search : '' %>">
                    </div>
                </div>

                <!-- Type Filter -->
                <div class="col-lg-3 col-md-3 col-sm-6">
                    <label for="typeFilter" class="form-label text-dark fw-semibold small"><i class="bi bi-filter me-1"></i> Tipo de Registro</label>
                    <select class="form-select bg-light border-light" id="typeFilter" name="type">
                        <option value="" <%= typeof selectedType === 'undefined' || selectedType === '' ? 'selected' : '' %>>Todos os Tipos</option>
                        <option value="perdido" <%= typeof selectedType !== 'undefined' && selectedType === 'perdido' ? 'selected' : '' %>>Perdidos</option>
                        <option value="encontrado" <%= typeof selectedType !== 'undefined' && selectedType === 'encontrado' ? 'selected' : '' %>>Encontrados</option>
                    </select>
                </div>

                <!-- Status Filter -->
                <div class="col-lg-3 col-md-3 col-sm-6">
                    <label for="statusFilter" class="form-label text-dark fw-semibold small"><i class="bi bi-check-circle me-1"></i> Status</label>
                    <select class="form-select bg-light border-light" id="statusFilter" name="status">
                        <option value="" <%= typeof selectedStatus === 'undefined' || selectedStatus === '' ? 'selected' : '' %>>Todos os Status</option>
                        <option value="ativo" <%= typeof selectedStatus !== 'undefined' && selectedStatus === 'ativo' ? 'selected' : '' %>>Ativos (Não Resolvidos)</option>
                        <option value="resolvido" <%= typeof selectedStatus !== 'undefined' && selectedStatus === 'resolvido' ? 'selected' : '' %>>Resolvidos</option>
                    </select>
                </div>

                <!-- Filter Button -->
                <div class="col-lg-1 col-md-12 text-end">
                    <button type="submit" class="btn btn-catolica w-100 py-2 rounded-3">
                        Filtrar
                    </button>
                </div>
            </form>
        </div>

        <!-- Items Feed Grid -->
        <% if (typeof items !== 'undefined' && items.length > 0) { %>
            <div class="row g-4">
                <% items.forEach(function(item) { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="card catolica-card h-100 border-0 shadow-sm d-flex flex-column">
                            <!-- Header Accent Bar based on Type -->
                            <div class="w-100" style="height: 6px; background-color: <%= item.type === 'perdido' ? '#f59e0b' : '#10b981' %>;"></div>

                            <!-- Card Body -->
                            <div class="card-body p-4 d-flex flex-column">
                                <!-- Badges -->
                                <div class="d-flex gap-2 mb-3">
                                    <span class="badge text-white px-3 py-2 rounded-pill fw-semibold" style="background-color: <%= item.type === 'perdido' ? '#f59e0b' : '#10b981' %>; font-size: 0.75rem;">
                                        <%= item.type === 'perdido' ? 'Perdido' : 'Encontrado' %>
                                    </span>
                                    <% if (item.status === 'resolvido') { %>
                                        <span class="badge bg-secondary text-white px-3 py-2 rounded-pill fw-semibold" style="font-size: 0.75rem;">
                                            Resolvido
                                        </span>
                                    <% } %>
                                </div>
                                <h5 class="card-title fw-bold text-dark mb-2 text-truncate-2" title="<%= item.title %>">
                                    <%= item.title %>
                                </h5>
                                
                                <p class="card-text text-secondary small text-truncate-3 mb-4 flex-grow-1">
                                    <%= item.description %>
                                </p>

                                <div class="border-top border-light pt-3 mt-auto">
                                    <!-- Meta 1: Location -->
                                    <div class="d-flex align-items-center text-secondary small mb-2">
                                        <i class="bi bi-geo-alt me-2 text-danger"></i>
                                        <span class="text-truncate"><strong>Local:</strong> <%= item.location %></span>
                                    </div>

                                    <!-- Meta 2: Date -->
                                    <div class="d-flex align-items-center text-secondary small">
                                        <i class="bi bi-calendar-event me-2 text-primary"></i>
                                        <span><strong>Data:</strong> <%= item.createdAt ? new Date(item.createdAt).toLocaleDateString('pt-BR') : new Date().toLocaleDateString('pt-BR') %></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Card Footer -->
                            <div class="card-footer bg-white border-0 p-4 pt-0">
                                <a href="/items/<%= item.id %>" class="btn btn-outline-catolica w-100 py-2 rounded-pill text-center d-block">
                                    Ver Detalhes
                                </a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <!-- Empty State -->
            <div class="text-center py-5 px-4 bg-white rounded-4 border border-light shadow-sm">
                <div class="d-inline-flex align-items-center justify-content-center p-4 rounded-circle mb-4" style="background-color: var(--primary-light);">
                    <i class="bi bi-search text-catolica fs-1" style="color: var(--primary-color);"></i>
                </div>
                <h3 class="fw-bold text-dark mb-2">Nenhum item encontrado</h3>
                <p class="text-secondary max-width-500 mx-auto mb-4">
                    Não encontramos registros correspondentes aos filtros ou buscas aplicados. Experimente alterar sua pesquisa ou seja o primeiro a registrar!
                </p>
                <div class="d-flex justify-content-center gap-3">
                    <% if (user) { %>
                        <a href="/items/new" class="btn btn-catolica px-4 py-2 rounded-pill shadow-sm">
                            Registrar Item
                        </a>
                    <% } else { %>
                        <a href="/register" class="btn btn-catolica px-4 py-2 rounded-pill shadow-sm">
                            Criar Conta
                        </a>
                    <% } %>
                    <a href="/items" class="btn btn-outline-secondary px-4 py-2 rounded-pill">
                        Limpar Filtros
                    </a>
                </div>
            </div>
        <% } %>
    </main>

    <%- include("../partials/footer") %>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
